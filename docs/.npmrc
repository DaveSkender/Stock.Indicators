# GitHub Packages registry for @facioquo scope.
# Requires NPM_TOKEN environment variable to be set with a GitHub token
# that has read:packages scope for the facioquo organization.
# In CI, set NPM_TOKEN=${{ secrets.GITHUB_TOKEN }} in the workflow step.
@facioquo:registry=https://npm.pkg.github.com
//npm.pkg.github.com/:_authToken=${NPM_TOKEN}
