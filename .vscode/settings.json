{
  "[markdown]": {
    "editor.defaultFormatter": "DavidAnson.vscode-markdownlint",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll.markdownlint": "explicit"
    }
  },
  "chat.useAgentSkills": true,
  "chat.useAgentsMdFile": true,
  "chat.useNestedAgentsMdFiles": true,
  "dotnet.defaultSolution": "Stock.Indicators.sln",
  "githubPullRequests.ignoredPullRequestBranches": [
    "main",
    "v3"
  ],
  "search.useIgnoreFiles": true, // default: true
  "search.exclude": {
    // not otherwise ignored
    "tests/**/*.json": true,
    "tests/**/*.csv": true,
    "docs/examples/**/*.json": true,
    "docs/.vitepress/cache": true,
    "docs/.vitepress/dist": true
  },
  "github.copilot.chat.claudeAgent.allowDangerouslySkipPermissions": true,
  "claudeCode.allowDangerouslySkipPermissions": true,
  "chat.tools.terminal.ignoreDefaultAutoApproveRules": true
}
