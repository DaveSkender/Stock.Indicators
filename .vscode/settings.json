{
  "[markdown]": {
    "editor.defaultFormatter": "DavidAnson.vscode-markdownlint",
  },
  "chat.useAgentsMdFile": true,
  "chat.useNestedAgentsMdFiles": true,
  "chat.customAgentInSubagent.enabled": true,
  "dotnet.defaultSolution": "Stock.Indicators.sln",
  "files.associations": {
    "*.md": "markdown"
  },
  "github.copilot.chat.copilotMemory.enabled": true,
  "github.copilot.chat.githubMcpServer.enabled": true,
  "github.copilot.chat.githubMcpServer.readonly": false,
  "github.copilot.chat.githubMcpServer.toolsets": [
    "default", // default: context, repos, issues, pull_requests, users
    "actions",
    "discussions",
    "copilot",
    "github_support_docs_search",
    "web_search"
  ],
  "githubPullRequests.ignoredPullRequestBranches": [
    "main",
    "v3"
  ],
  "search.useIgnoreFiles": true, // default: true
  "search.exclude": {
    // not otherwise ignored
    "tests/**/*.json": true,
    "tests/**/*.csv": true,
    "docs/examples/**/*.json": true,
    "docs/.vitepress/cache": true,
    "docs/.vitepress/dist": true,
    "docs/.vitepress/public/data/**/*.json": true
  }
}
