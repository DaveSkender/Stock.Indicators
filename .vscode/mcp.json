{
  "servers": {
    "codacy": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@codacy/codacy-mcp@latest"
      ],
      "env": {
        "CODACY_ACCOUNT_TOKEN": "${input:codacy_account_token}"
      }
    },
    "context7": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp@latest"
      ]
    },
    "microsoft-docs": {
      "type": "http",
      "url": "https://learn.microsoft.com/api/mcp"
    }
  },
  "inputs": [
    {
      "id": "codacy_account_token",
      "type": "promptString",
      "description": "Your personal Codacy Account API token (from app.codacy.com → Account). Required.",
      "password": true
    }
  ]
}
